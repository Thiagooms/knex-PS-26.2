{
  "name": "knex-backend-case",
  "version": "1.0.0",
  "description": "API da TechMart — desafio backend KNEX Consultoria Jr.",
  "private": true,
  "license": "ISC",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "pnpm --filter api dev",
